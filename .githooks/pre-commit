#!/usr/bin/env bash

set -euo pipefail

if [[ "${LOGICAL_COMMIT_BYPASS:-0}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${repo_root}" ]]; then
  echo "pre-commit: could not resolve repository root."
  exit 1
fi

staged_files="$(git -C "${repo_root}" diff --cached --name-only --diff-filter=ACMRD)"
if [[ -z "${staged_files}" ]]; then
  echo "pre-commit: no staged changes found."
  echo "Stage files first with 'git add ...'."
  exit 1
fi

file_count="$(printf '%s\n' "${staged_files}" | sed '/^$/d' | wc -l | tr -d ' ')"
max_files="${LOGICAL_COMMIT_MAX_FILES:-20}"

if (( file_count > max_files )); then
  echo "pre-commit: staged file count ${file_count} exceeds limit ${max_files}."
  echo "Split this into smaller logical commits."
  echo "Temporary bypass: LOGICAL_COMMIT_BYPASS=1 git commit ..."
  exit 1
fi

added=0
deleted=0
while IFS=$'\t' read -r a d _; do
  [[ -z "${a}" ]] && continue
  [[ "${a}" == "-" ]] && a=0
  [[ "${d}" == "-" ]] && d=0
  added=$((added + a))
  deleted=$((deleted + d))
done < <(git -C "${repo_root}" diff --cached --numstat --diff-filter=ACMRD)

changed_lines=$((added + deleted))
max_lines="${LOGICAL_COMMIT_MAX_LINES:-600}"

if (( changed_lines > max_lines )); then
  echo "pre-commit: staged line delta ${changed_lines} exceeds limit ${max_lines}."
  echo "Split this into smaller logical commits."
  echo "Temporary bypass: LOGICAL_COMMIT_BYPASS=1 git commit ..."
  exit 1
fi

exit 0
