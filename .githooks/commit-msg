#!/usr/bin/env bash

set -euo pipefail

msg_file="${1:-}"
if [[ -z "${msg_file}" || ! -f "${msg_file}" ]]; then
  echo "commit-msg: missing commit message file argument."
  exit 1
fi

subject="$(sed -n '1p' "${msg_file}" | tr -d '\r')"
subject_lower="$(printf '%s' "${subject}" | tr '[:upper:]' '[:lower:]')"

if [[ -z "${subject}" ]]; then
  echo "commit-msg: empty commit subject."
  exit 1
fi

case "${subject}" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

subject_len="${#subject}"
if (( subject_len > 72 )); then
  echo "commit-msg: subject is ${subject_len} chars; keep it <= 72."
  exit 1
fi

if [[ "${subject_lower}" =~ ^(wip|tmp|temp|update|updates|changes|misc|stuff|fix|test)$ ]]; then
  echo "commit-msg: generic subject '${subject}' is not allowed."
  echo "Use '<area>: <meaningful change>' instead."
  exit 1
fi

if ! [[ "${subject}" =~ ^[^:[:space:]][^:]*:\ .+ ]]; then
  echo "commit-msg: expected subject format '<area>: <meaningful change>'."
  echo "Example: fluidsim-gpu: reduce host syncs for thermal logging"
  exit 1
fi

exit 0
